# Azure AD App Registration credentials
# See HOWTO-ENTRA-APPREG-DELEGATED.md for setup instructions.

AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id

# Microsoft Sentinel / Log Analytics workspace
# Enables run_sentinel_query and get_sentinel_tables tools.
# Find this in Azure Portal → Log Analytics workspaces → your workspace → Overview → Workspace ID.
# Requires Log Analytics API > Data.Read permission on the app registration.

# SENTINEL_WORKSPACE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx


# Authentication method — choose one

# Option 1: Interactive browser (recommended for personal/dev use)
# Leave AZURE_CLIENT_SECRET and AZURE_CLIENT_CERTIFICATE_PATH unset.
# A browser window will open for sign-in on first use.
# Requires a public client app with ThreatHunting.Read.All (Delegated) on Microsoft Graph.

# Option 2: Certificate authentication (service principal, no user required)
# AZURE_CLIENT_CERTIFICATE_PATH=/path/to/combined.pem
# AZURE_CLIENT_CERTIFICATE_PASSWORD=optional-password-if-encrypted

# Option 3: Client secret authentication (service principal, no user required)
# AZURE_CLIENT_SECRET=your-client-secret
